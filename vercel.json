{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/guardian.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/guardian(.*)",
      "dest": "api/guardian.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
